# --- Lofty ---
LOFTY_API_KEY=                # Same key as the existing lofty-bot service. Copy from there.

# --- Anthropic (used by tax_scraper for HTML interpretation) ---
ANTHROPIC_API_KEY=

# --- Pipeline stage IDs ---
# Source pipelines this bot audits: HVT, Fatty, Hot Occupied/Alive.
STAGE_HVT=606230
STAGE_FATTY=606229
STAGE_HOT_OCC_ALIVE=648757
# Destination stages (only used when AUTO_MOVE=1). Each recommendation routes here:
STAGE_VAULT_HOT_OCC_ALIVE=428742   # VAULT
STAGE_DO_NOT_CONTACT=425581        # DNC

# --- Slack ---
# Incoming webhook URL pinned to #dirtydeedbot.
SLACK_WEBHOOK_URL=

# --- Behaviour flags ---
# DRY_RUN=1 — read leads + decide, but DON'T move them or post anything.
DRY_RUN=0
# AUTO_MOVE=0 — REPORT ONLY: decide + post Slack, never move a lead (Raul reviews & moves).
AUTO_MOVE=0
# LIMIT — max leads to process per run. 0 = all.
CLEANUP_LIMIT=0
# Days back a tax payment counts as "recent" (Raul's rule keys off the last year).
TAX_LOOKBACK_DAYS=365

# --- Decision thresholds (Raul's logic; tune without a redeploy) ---
# THE PROFIT MATH (#1 filter): net = value - owed - HEIR - ATTORNEY - COMMISSION%*value
#   value = lower of (assessed, Zillow); their AVERAGE if they differ by > BIG_DISCREPANCY.
#   net < MIN_NET_PROFIT  ->  flagged for Raul's decision (never auto-removed).
HEIR_COST=8000              # avg paid to heirs per deal
ATTORNEY_COST=5000          # avg attorney fees to close
COMMISSION_PCT=0.06         # commissions + closing, applied to value
MIN_NET_PROFIT=60000        # target net; below this = flag "your call to remove"
BIG_DISCREPANCY=0.25        # |assessed-zillow|/max above this = use the average
HVT_MIN_VALUE=80000         # min value for a deceased lead to be HVT
SUBSTANTIAL_PAYMENT=1000    # a recent payment >= this = real "intent to pay"
DEAD_RATIO=0.02             # taxes-owed/value below this = no motivation -> DNC
LOW_RATIO=0.04              # below this = limited motivation -> Occupied/Alive
