# --- Lofty ---
LOFTY_API_KEY=                # Same key as the existing lofty-bot service. Copy from there.

# --- Anthropic (used by tax_scraper for HTML interpretation) ---
ANTHROPIC_API_KEY=

# --- Pipeline stage IDs ---
# Source pipelines this bot audits.
STAGE_HVT=606230
STAGE_FATTY=606229

# Destination when the decision is VAULT.
STAGE_VAULT_HOT_OCC_ALIVE=428742

# --- Slack ---
# Incoming webhook URL pinned to #dirtydeedbot.
SLACK_WEBHOOK_URL=

# --- Behaviour flags ---
# DRY_RUN=1 — read leads + decide, but DON'T move them or post anything.
DRY_RUN=0

# AUTO_MOVE=1 — attempt actual pipeline moves via Lofty API.
AUTO_MOVE=1

# LIMIT — max leads to process per run. 0 = all.
CLEANUP_LIMIT=0

# Payment threshold (USD) at/above which we VAULT instead of FLAG.
PAYMENT_VAULT_THRESHOLD=1000
